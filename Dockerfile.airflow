# ─────────────────────────────────────────────────────────────────────────────
# Custom Airflow image used for the BDM P2 Trusted-Zone DAG.
#
# The base apache/airflow image cannot run PySpark out of the box (no JRE)
# and lacks the cleaning-job dependencies. This image adds:
#   - default-jre-headless (Java 17 on Debian Bookworm; works for Spark 3.5)
#   - PySpark + lxml + bs4 + duckdb + boto3 + pandas + python-dotenv
#
# Built and used by docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────
FROM apache/airflow:2.9.0

USER root
RUN apt-get update \
 && apt-get install -y --no-install-recommends default-jre-headless \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# PySpark needs JAVA_HOME at runtime.
ENV JAVA_HOME=/usr/lib/jvm/default-java

USER airflow
RUN pip install --no-cache-dir \
    "pyspark==3.5.*" \
    "duckdb>=1.0.0" \
    "beautifulsoup4>=4.12" \
    "lxml>=5.0" \
    "boto3>=1.34" \
    "pandas>=2.0" \
    "python-dotenv>=1.0" \
    "deltalake>=0.18" \
    "requests>=2.31"

# Exploitation Zone embedding job (corpus_chunks.py). torch is pinned to the
# CPU-only wheel so the image stays ~1 GB lighter (no CUDA) — this stack runs
# embedding on CPU in local-mode Spark.
RUN pip install --no-cache-dir \
      --extra-index-url https://download.pytorch.org/whl/cpu \
      "torch>=2.0,<3.0" \
 && pip install --no-cache-dir \
      "sentence-transformers>=3.0.0" \
      "pymilvus>=2.4.0,<2.5.0"

# Consumption Zone — Anthropic-backed LLM client (consumption/llm.py).
# Separate layer so the heavy torch/ST/pymilvus layers above stay cached.
RUN pip install --no-cache-dir "anthropic>=0.40.0"
