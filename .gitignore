# ─── Virtual Environments ────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
*.env

# ─── Python Cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Landing Zone (raw data — never committed to git) ─────────────────────────
# The landing_zone/ folder is the MinIO data volume. It contains raw ingested
# data files and MinIO internal metadata. None of this belongs in version control.
landing_zone/

# ─── Trusted Zone — DuckDB files ──────────────────────────────────────────────
# Output of the Trusted Zone cleaning jobs. Regenerated from the landing zone.
duckdb/

# ─── Jupyter / IPython ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── OS / Editor Artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Airflow / MinIO Runtime Artifacts ────────────────────────────────────────
logs/
airflow.db
airflow.cfg
airflow_settings.yaml

# ─── Consumption Zone — generated episodes ────────────────────────────────────
# Podcast episodes are produced at runtime by the consumption agents (and are
# owned by the uid-50000 Airflow container user). Demo artifacts, regenerated.
consumption/episodes/*
!consumption/episodes/.gitkeep

# ─── Build / Distribution ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
