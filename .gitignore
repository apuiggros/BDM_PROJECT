# ─── Virtual Environments ────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
*.env

# ─── Python Cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Landing Zone (raw data — never committed to git) ─────────────────────────
# The landing_zone/ folder is the MinIO data volume. It contains raw ingested
# data files and MinIO internal metadata. None of this belongs in version control.
landing_zone/

# ─── Jupyter / IPython ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── OS / Editor Artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Airflow / MinIO Runtime Artifacts ────────────────────────────────────────
logs/
airflow.db
airflow.cfg
airflow_settings.yaml

# ─── Build / Distribution ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
